[Unit]
Description=yolink_bridge
Wants=network-online.target
After=network-online.target
# If process fails twice within 30 seconds, don't restart.
StartLimitIntervalSec=30
StartLimitBurst=5

[Service]
User=root
Group=root
WorkingDirectory=/home/ha/yolink_bridge/
ExecStart='/home/ha/yolink_bridge/start_yolink_bridge'
ExecStartPost=/bin/sleep 5
Restart=on-failure

[Install]
WantedBy=multi-user.target
